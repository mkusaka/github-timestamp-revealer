{
  "devDependencies": {
    "@crxjs/vite-plugin": "2.7.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@types/chrome": "0.2.2",
    "@vitest/ui": "4.1.10",
    "happy-dom": "20.10.6",
    "oxlint": "1.74.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  },
  "name": "github-timestamp-revealer",
  "version": "0.1.4",
  "main": "index.js",
  "repository": "https://github.com/mkusaka/github-timestamp-revealer.git",
  "author": "mkusaka <hinoshita1992@gmail.com>",
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "dev": "vite --host 127.0.0.1 --port 5173",
    "dev:watch": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint . --import-plugin --tsconfig ./tsconfig.json",
    "lint:fix": "oxlint . --import-plugin --tsconfig ./tsconfig.json --fix",
    "lint:ci": "oxlint . --import-plugin --tsconfig ./tsconfig.json --deny-warnings",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "package": "rm -f package.zip && pnpm build && find dist -name .DS_Store -delete && cd dist && zip -r ../package.zip . -x '*.DS_Store'"
  },
  "packageManager": "pnpm@11.9.0"
}
